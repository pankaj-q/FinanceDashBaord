# PostgreSQL Configuration
POSTGRES_USER=finance
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=finance_dashboard

# Database URL for backend
DATABASE_URL=postgresql://finance:change_me_strong_password_here@db:5432/finance_dashboard

# JWT Secrets (GENERATE NEW SECURE STRINGS FOR PRODUCTION!)
JWT_SECRET=generate-a-32-character-random-string-here
JWT_REFRESH_SECRET=generate-another-32-character-random-string

# Environment
NODE_ENV=production
PORT=3001
